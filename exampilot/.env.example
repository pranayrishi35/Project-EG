# Environment Variables — ExamPilot
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values from:
# https://supabase.com/dashboard → Project Settings → API
#
# NEVER commit .env.local to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Optional: only needed for admin tasks (never expose to the browser) ─────
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── Google Gemini API (server-side only — NEVER prefix with NEXT_PUBLIC_) ───
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
